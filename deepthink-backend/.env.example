# ============================================
# DeepThink Backend Configuration
# ============================================

# --------------------------------------------
# Required: Authentication Keys
# --------------------------------------------

# Admin API Key (for managing models and credentials via /admin/*)
ADMIN_API_KEY=your-admin-api-key-here

# Credentials Encryption Key (for encrypting stored API keys, min 32 chars)
CREDENTIALS_ENC_KEY=your-32-character-encryption-key!

# App API Key (for third-party clients calling /v1/chat/completions)
# Leave empty to disable authentication (not recommended for production)
APP_API_KEY=your-app-api-key-here

# --------------------------------------------
# Optional: LLM Provider API Keys (Legacy)
# You can also configure these via Web UI Credentials
# --------------------------------------------

GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=

# Optional: Custom OpenAI-compatible endpoint
OPENAI_BASE_URL=

# --------------------------------------------
# Optional: Tools
# --------------------------------------------

# Tavily API for web search
TAVILY_API_KEY=

# --------------------------------------------
# Server Configuration
# --------------------------------------------

API_HOST=0.0.0.0
API_PORT=8080

# CORS allowed origins (comma-separated)
CORS_ALLOW_ORIGINS=http://localhost:3000

# Base URL allowlist for SSRF protection (comma-separated)
BASE_URL_ALLOWLIST=https://api.openai.com,https://api.anthropic.com,https://api.deepseek.com,https://generativelanguage.googleapis.com,https://api.x.ai,https://api.mistral.ai

# --------------------------------------------
# Data Persistence
# --------------------------------------------

# Directory for storing model_registry.json and credentials.json
DATA_DIR=/app/data

# SQLite database for sessions (optional)
DATABASE_URL=sqlite:///deepthink_sessions.db
